{
  "id": "donut-case",
  "title": "도넛 실종 사건",
  "tagline": "사라진 도넛의 진실을 찾아라",
  "version": "1.1.0",
  "startNodeId": "start",
  "nodes": {
    "start": {
      "id": "start",
      "title": "사건 발생",
      "body": "사무실 냉장고의 마지막 도넛이 사라졌다. 가장 먼저 무엇을 할까?",
      "choices": [
        {
          "id": "check-cam",
          "text": "복도 CCTV를 확인한다",
          "to": "cam",
          "effects": [
            {
              "type": "addClue",
              "clue": "cctv-frame"
            },
            {
              "type": "addStat",
              "stat": "wit",
              "delta": 1
            }
          ],
          "imageUrl": null
        },
        {
          "id": "ask-intern",
          "text": "신입에게 정중히 물어본다",
          "to": "intern",
          "effects": [
            {
              "type": "setFlag",
              "flag": "internTrust",
              "value": true
            }
          ],
          "imageUrl": "./src/content/images/missing-choice.png"
        }
      ],
      "imageUrl": "./src/content/images/office-donut.svg"
    },
    "cam": {
      "id": "cam",
      "title": "CCTV 확인",
      "body": "영상에는 팀장이 도넛 상자를 들고 회의실로 들어가는 모습이 찍혔다.",
      "choices": [
        {
          "id": "collect-sugar-clue",
          "text": "프레임을 확대해 설탕가루를 확인한다",
          "to": "cam",
          "cond": [
            {
              "type": "hasClue",
              "clue": "cctv-frame"
            }
          ],
          "effects": [
            {
              "type": "addItem",
              "item": "sugar-proof"
            },
            {
              "type": "setFlag",
              "flag": "hasSugarProof",
              "value": true
            }
          ],
          "disabledReason": "먼저 CCTV부터 확인해 단서를 확보해야 합니다."
        },
        {
          "id": "go-meeting-room",
          "text": "회의실 문을 열고 들어간다",
          "to": "meeting-room"
        }
      ],
      "imageUrl": null
    },
    "intern": {
      "id": "intern",
      "title": "신입의 증언",
      "body": "신입: \"팀장님이 배고프면 추리가 안 된다고 하셨어요...\"",
      "choices": [
        {
          "id": "accuse-intern",
          "text": "신입을 범인으로 몰아간다",
          "to": "bad-ending"
        },
        {
          "id": "follow-hint",
          "text": "단서를 믿고 회의실로 간다",
          "to": "meeting-room",
          "cond": [
            {
              "type": "flagEquals",
              "flag": "internTrust",
              "value": true
            }
          ]
        }
      ],
      "imageUrl": "./src/content/images/missing-intern.png"
    },
    "meeting-room": {
      "id": "meeting-room",
      "title": "회의실의 진실",
      "body": "문이 잠겨 있다. 눈치와 운으로 전말을 밝혀낼 수 있을까?",
      "choices": [
        {
          "id": "logic-check",
          "text": "논리적으로 상황을 재구성한다",
          "check": {
            "stat": "wit",
            "dc": 10,
            "roll": "d20",
            "bonusFlag": "hasSugarProof"
          },
          "onPass": {
            "to": "good-ending",
            "effects": [
              {
                "type": "addStat",
                "stat": "reputation",
                "delta": 1
              }
            ]
          },
          "onFail": {
            "to": "bad-ending"
          }
        },
        {
          "id": "coin-flip-entry",
          "text": "동전을 던져 모험한다",
          "check": {
            "stat": "nerve",
            "dc": 1,
            "roll": "coin"
          },
          "onPass": {
            "to": "good-ending"
          },
          "onFail": {
            "to": "bad-ending"
          }
        },
        {
          "id": "secret-route",
          "text": "설탕가루 증거를 문틈에 밀어 넣는다",
          "cond": [
            {
              "type": "hasItem",
              "item": "sugar-proof"
            },
            {
              "type": "visitedNode",
              "nodeId": "cam"
            }
          ],
          "effects": [
            {
              "type": "goto",
              "to": "good-ending"
            }
          ]
        }
      ]
    },
    "good-ending": {
      "id": "good-ending",
      "title": "해피 엔딩",
      "body": "당신은 사건을 평화롭게 마무리했다.",
      "choices": [],
      "ending": {
        "id": "ending-share",
        "kind": "success",
        "title": "도넛은 사랑을 싣고",
        "summary": "성급한 의심 대신 확인을 택해 모두가 행복해졌다."
      }
    },
    "bad-ending": {
      "id": "bad-ending",
      "title": "오해 엔딩",
      "body": "성급한 단정으로 사무실 단톡방에 사과문을 올리게 되었다.",
      "choices": [],
      "ending": {
        "id": "ending-oops",
        "kind": "gag",
        "title": "사과문 장인",
        "summary": "추리는 없고 사과만 남았다."
      }
    }
  }
}
