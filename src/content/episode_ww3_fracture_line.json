  "version": "1.1.0",
  "startNodeId": "start",
  "nodes": {
    "start": {
      "id": "start",
      "title": "D-3, 동시다발 위기",
      "body": "새벽 4시 10분. 국경 감시 레이더 오작동, 주요 항만 전력망 장애, SNS발 대규모 허위영상이 동시에 터졌다. 정보는 넘치지만 신뢰할 수 있는 사실은 거의 없다. 당신은 국가안보위기대응센터의 총괄 조정관으로서 첫 30분의 결정을 내려야 한다.",
      "choices": [
        {
          "id": "to-brief-room",
          "text": "군 상황실에서 국경 정보부터 검증한다",
          "to": "brief_room",
          "effects": [
            {
              "type": "addStat",
              "stat": "wit",
              "delta": 1
            }
          ]
        },
        {
          "id": "to-media-room",
          "text": "여론전 대응팀을 소집해 허위정보 확산부터 끊는다",
          "to": "media_room",
          "effects": [
            {
              "type": "setFlag",
              "flag": "publicCalm",
              "value": true
            }
          ]
        },
        {
          "id": "to-cyber-center",
          "text": "사이버안보센터로 이동해 항만 장애 원인을 추적한다",
          "to": "cyber_center",
          "effects": [
            {
              "type": "addItem",
              "item": "forensic_pack"
            }
          ]
        }
      ],
      "imageUrl": "https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?auto=format&fit=crop&w=1400&q=80"
    },
